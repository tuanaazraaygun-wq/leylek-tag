{
  "expo": {
    "name": "Leylek TAG",
    "slug": "leylektag-app",
    "owner": "leylektagappp",
    "version": "1.0.31",
    "orientation": "portrait",
    "icon": "./assets/images/leylek-logo-premium.png",
    "scheme": "leylektag",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leylektag.app",
      "buildNumber": "7",
      "config": {
        "googleMapsApiKey": "AIzaSyAKqhXyi2cUC3GHLxjom4R_tQ3UfR5auUw"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Uygulama içi sesli görüşme, sesli komut ve bas-konuş özellikleri için mikrofon izni gereklidir.",
        "NSSpeechRecognitionUsageDescription": "Bas-konuş özelliğinde konuşmanızı metne çevirmek için konuşma tanıma izni gereklidir.",
        "NSCameraUsageDescription": "QR kod tarama ve profil fotoğrafı işlemleri için kamera izni gereklidir.",
        "NSLocationWhenInUseUsageDescription": "Yakındaki sürücüleri bulmak ve yolculukta konum paylaşımı için konum izni gereklidir.",
        "NSPhotoLibraryUsageDescription": "Profil ve doğrulama görsellerini seçmek için fotoğraf erişimi gereklidir.",
        "NSBluetoothAlwaysUsageDescription": "Bluetooth kulaklık kullanımı için izin gereklidir.",
        "NSBluetoothPeripheralUsageDescription": "Bluetooth cihazları ile bağlantı için izin gereklidir.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },

    "android": {
      "package": "com.leylektag.app",
      "versionCode": 32,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/leylek-logo-premium.png",
        "backgroundColor": "#08111F"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAKqhXyi2cUC3GHLxjom4R_tQ3UfR5auUw"
        }
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "largeHeap": true,
            "enableProguardInReleaseBuilds": false,
            "newArchEnabled": false,
            "enableMinifyInReleaseBuilds": false,
            "usesCleartextTraffic": false
          },
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": false
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Yakındaki sürücüleri bulmak ve yolculukta konum paylaşımı için konum izni gereklidir."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod taramak ve profil fotoğrafı çekmek için kamera izni gereklidir."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Sesli görüşme, sesli komut ve bas-konuş için mikrofon izni gereklidir."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Uygulama içi sesli görüşme, sesli komut ve bas-konuş özellikleri için mikrofon izni gereklidir.",
          "speechRecognitionPermission": "Bas-konuş özelliğinde konuşmanızı metne çevirmek için konuşma tanıma izni gereklidir.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/leylek-logo-premium.png",
          "color": "#22D3EE",
          "sounds": [],
          "defaultChannelId": "default"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "splash": {
      "image": "./assets/images/leylek-logo-premium.png",
      "resizeMode": "contain",
      "backgroundColor": "#08111F"
    },

    "extra": {
      "router": {},
      "backendUrl": "https://api.leylektag.com",
      "companyLegalName": "Karekod Teknoloji ve Yazılım A.Ş.",
      "leylekZekaPath": "ai/leylekzeka",
      "eas": {
        "projectId": "08db7f23-ccd6-4e54-a2ce-5ab599335d0c"
      }
    }
  }
}