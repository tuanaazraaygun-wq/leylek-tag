{
  "expo": {
    "name": "Leylek TAG",
    "slug": "leylektag-app",
    "owner": "leylektagappp",
    "version": "1.0.22",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "leylektag",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leylektag.app",
      "buildNumber": "7",
      "config": {
        "googleMapsApiKey": "AIzaSyAKqhXyi2cUC3GHLxjom4R_tQ3UfR5auUw"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sürücü ve yolcu arasında sesli ve görüntülü görüşme yapmak için mikrofon izni gereklidir.",
        "NSCameraUsageDescription": "Görüntülü arama yapmak ve profil fotoğrafı çekmek için kamera izni gereklidir.",
        "NSLocationWhenInUseUsageDescription": "Yakındaki sürücüleri bulmak ve konumunuzu paylaşmak için konum izni gereklidir.",
        "NSLocationAlwaysUsageDescription": "Yolculuk sırasında konumunuzu takip etmek için konum izni gereklidir.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Sürücü ve yolcu eşleştirmesi için konum izni gereklidir.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "location"
        ],
        "NSBluetoothAlwaysUsageDescription": "Bluetooth kulaklık kullanımı için izin gereklidir.",
        "NSBluetoothPeripheralUsageDescription": "Bluetooth cihazları ile bağlantı için izin gereklidir.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "157.173.113.156": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          }
        }
      }
    },

    "android": {
      "package": "com.leylektag.app",
      "versionCode": 24,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.READ_PHONE_STATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAKqhXyi2cUC3GHLxjom4R_tQ3UfR5auUw"
        }
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "largeHeap": true,
            "enableProguardInReleaseBuilds": false,
            "newArchEnabled": false,
            "enableMinifyInReleaseBuilds": false,
            "usesCleartextTraffic": true
          },
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": false
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Konumunuzu şoförlere göstermek için konum izni gereklidir."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod taramak ve profil fotoğrafı çekmek için kamera izni gereklidir."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Sesli görüşme için mikrofon izni gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#3FA9F5",
          "sounds": [],
          "defaultChannelId": "default"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },

    "extra": {
      "router": {},
      "backendUrl": "https://api.leylektag.com",
      "leylekZekaPath": "ai/leylekzeka",
      "eas": {
        "projectId": "08db7f23-ccd6-4e54-a2ce-5ab599335d0c"
      }
    }
  }
}